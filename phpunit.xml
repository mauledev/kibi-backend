<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- The Docker container defines these as real OS env vars (docker-compose),
             which land in BOTH $_ENV and $_SERVER. Laravel's env() resolves $_SERVER
             first, and PHPUnit's <env> only overrides $_ENV — so without the <server>
             entries below, tests run against kibi_db and RefreshDatabase WIPES the
             dev database. force="true" is required to override the existing values. -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="DB_CONNECTION" value="pgsql" force="true"/>
        <env name="DB_DATABASE" value="kibi_db_test" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <server name="APP_ENV" value="testing" force="true"/>
        <server name="BCRYPT_ROUNDS" value="4" force="true"/>
        <server name="CACHE_STORE" value="array" force="true"/>
        <server name="DB_CONNECTION" value="pgsql" force="true"/>
        <server name="DB_DATABASE" value="kibi_db_test" force="true"/>
        <server name="QUEUE_CONNECTION" value="sync" force="true"/>
        <server name="SESSION_DRIVER" value="array" force="true"/>
    </php>
</phpunit>
