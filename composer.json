{
    "name": "school-admin/backend",
    "description": "School Admin Backend - Clean Architecture",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "larastan/larastan": "^3.4",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "format": "@php vendor/bin/pint",
        "format:test": "@php vendor/bin/pint --test",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "quality": [
            "@format:test",
            "@analyse"
        ]
    }
}
