{
    "name": "school-admin/backend",
    "description": "School Admin Backend - Clean Architecture",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "larastan/larastan": "^3.4",
        "phpstan/phpstan": "^2.1",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.24"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "format": "@php vendor/bin/pint",
        "format:test": "@php vendor/bin/pint --test",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "quality": [
            "@format:test",
            "@analyse"
        ],
        "test": "@php vendor/bin/pest",
        "test:unit": "@php vendor/bin/pest --filter=Unit",
        "test:feature": "@php vendor/bin/pest --filter=Feature"
    }
}
