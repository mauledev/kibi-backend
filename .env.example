APP_NAME="School Admin"
APP_ENV=local
APP_KEY=base64:J7xK3hN8mP2qL5rT9vW1yZ4aB6cD9eF2gH5iJ8kL1nO4pQ7sT0uV3wX6yZ9aC2bD5e
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_URL_FRONTEND=http://{APP_TENANT}.localhost:5173

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=school_admin
DB_USERNAME=postgres
DB_PASSWORD=postgres

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS=email@kibi.com
MAIL_SUPPORT_NAME="Kibi Support"

API_PREFIX=api

# Login rate limiting (route-level "login" throttle)
# max attempts per credential (tenant + email + ip) / per-IP backstop ceiling
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_DECAY_MINUTES=15
AUTH_LOGIN_IP_MAX_ATTEMPTS=30

# Comma-separated IPs/CIDRs of the load balancer / reverse proxy (e.g. 10.0.0.0/8).
# Required in production so $request->ip() is the real client IP (throttle + audit).
# Leave empty in local: no proxy is trusted.
TRUSTED_PROXIES=
